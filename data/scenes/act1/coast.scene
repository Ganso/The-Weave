# Acto 1 — Escena 4: costa de la Isla de los Tejedores (guión definitivo)
# Llegada en la nave de vapor, primer combate físico (jabalíes, sin vara)
# y curación de Clio. Textos placeholder pendientes de guión.
scene act1_coast

level coast_bg_tile coast_bg_map coast_front_tile coast_front_map coast_pal 640 user_right 3
limits 0 154 275 204
item 0 item_coast_seagull PAL0 520 176 0 0 0 0 FORCE_BACKGROUND    # gaviota junto a la roca
set rod off                   # Linus aún no tiene el bastón
character CHR_linus
character CHR_clio
active CHR_linus
move_instant CHR_linus -30 174
move_instant CHR_clio -60 174
follow CHR_clio on
show CHR_linus on
show CHR_clio on

call act1_coast_arrive        # olas + gaviota
say ACT1_COAST A1_COAST_ARRIVE sound
move CHR_linus 60 174

# Exploración hasta la zona del combate
set movement on
set scroll on
wait_scroll 200

# Combate físico: jabalíes (reintento si la vida llega a cero)
label coast_combat
say ACT1_COAST A1_COAST_COMBAT sound
call act1_coast_boars
if_defeated goto coast_fail

# Clio ha sido herida: canta el patrón de Curación
say ACT1_COAST A1_COAST_HEAL sound
call act1_coast_heal

# Avanzar hacia la choza
say ACT1_COAST A1_COAST_ONWARD sound
set movement on
wait_scroll 318
next_scene act1_hut

label coast_fail
say ACT1_COAST A1_COAST_DEFEAT sound
goto coast_combat
