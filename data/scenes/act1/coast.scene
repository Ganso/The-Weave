# Acto 1 — Escena 4: costa de la Isla de los Tejedores (guión definitivo)
# Lugar de paso: llegada en la nave de vapor (la gaviota alza el vuelo) y
# exploración con el árbol rojo examinable, camino del interior de la isla.
# Textos placeholder pendientes de guión.
scene act1_coast

level coast_bg_tile coast_bg_map coast_front_tile coast_front_map coast_pal 640 user_right 3
limits 0 134 275 172
item 0 item_coast_seagull PAL_BACKGROUND 520 112 0 0 0 0 FORCE_BACKGROUND    # gaviota (alza el vuelo al llegar al árbol)
# item 1 item_coast_leaves PAL_BACKGROUND 478 156 24 0 8 8 CALCULATE_DEPTH      # el árbol rojo (hojas al pie: objeto examinable)
item 1 item_coast_tree PAL_BACKGROUND 478 23 106 8 11 123 CALCULATE_DEPTH  # el árbol rojo
set rod off                   # Linus aún no tiene el bastón
character CHR_linus
character CHR_clio
active CHR_linus
move_instant CHR_linus -30 160
move_instant CHR_clio -60 160
follow CHR_clio on
show CHR_linus on
show CHR_clio on

say ACT1_COAST A1_COAST_ARRIVE sound      # rótulo: "Isla desconocida / Un mes más tarde"
call act1_coast_arrive        # olas + la gaviota sale volando
move CHR_linus 60 160
say_cluster ACT1_COAST A1_COAST_L1 sound  # "Por fin llegamos, madre..." 

# Exploración de TODO el tramo: la gaviota vuela al llegar al árbol, y el
# árbol (item 1) se puede examinar; el hook termina al final del mapa
set movement on
set scroll on
call act1_coast_explore

# La playa es un lugar de paso: hacia el interior de la isla
say_cluster ACT1_COAST A1_COAST_ONWARD sound
next_scene act1_island
