# Acto 1 — Bosque: tutorial de hechizos y combate contra los WeaverGhosts
scene act1_forest

# --- Montaje del bosque, items, personajes, vara y 4 hechizos (antes en act1_forest_setup) ---
level forest_bg_tile forest_bg_map forest_front_tile forest_front_map forest_dark_pal 1440 user_right 3
limits 0 134 275 172
item 0 item_forest_fg1_sprite PAL0 260 160 0 0 0 0 FORCE_FOREGROUND    # roca 1
item 1 item_forest_fg5_sprite PAL0 180 0 0 0 0 0 FORCE_FOREGROUND      # árbol (vertical)
item 2 item_forest_fg2_sprite PAL0 440 152 0 0 0 0 FORCE_FOREGROUND    # roca 2
item 3 item_forest_fg3_sprite PAL0 880 160 0 0 0 0 FORCE_FOREGROUND    # roca 3
item 4 item_forest_fg4_sprite PAL0 1400 104 0 0 0 0 FORCE_FOREGROUND   # árbol (grande)
item 5 item_forest_fg1_sprite PAL0 1050 160 0 0 0 0 FORCE_FOREGROUND   # roca 1
item 6 item_forest_fg5_sprite PAL0 1270 0 0 0 0 0 FORCE_FOREGROUND     # árbol (vertical)
set rod on                    # vara: fijar ANTES de character CHR_linus (decide su sprite)
character CHR_linus
character CHR_clio
active CHR_linus
move_instant CHR_linus -30 154
move_instant CHR_clio -30 154
follow CHR_clio on            # Clio sigue a Linus
enable_spell SPELL_THUNDER
enable_spell SPELL_HIDE
enable_spell SPELL_OPEN
enable_spell SPELL_SLEEP
move CHR_linus 50 154         # entrar en escena (SCROLL_START_DISTANCE+10)
anim CHR_linus ANIM_IDLE      # posar en reposo antes de hablar

say_cluster ACT1_FOREST A1_FOREST_SOME_TIME_LATER sound
call act1_forest_pad_hint    # aviso si el mando es de 3 botones
call act1_forest_day         # fade a la paleta de día

# Control al jugador: pasear hasta la zona del combate
set scroll on
set movement on
set interface on
set spells on
wait_scroll 360

# COMBATE
call act1_forest_enemies     # aparecen los dos WeaverGhosts
combat

# Final de la demo
set interface off
say_cluster ACT1_FOREST A1_FOREST_THATS_ALL sound
fade_out 120
hard_reset
