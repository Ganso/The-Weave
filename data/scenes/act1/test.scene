# ============================================================================
# BANCO DE PRUEBAS del motor de escenas — NO enlazado desde el flujo del juego.
# Se llega con HACK_START_SCENE "act1_test" (core/hack.h) o desde la smoke ROM.
# Documentación completa de qué prueba cada sección: docs/test_scene.md
#
# Estructura: intro corta + HUB (menú de 4 opciones) con secciones que vuelven
# al hub al terminar. Ejercita TODOS los ops del DSL, incluidos los nuevos
# anim y wait_press, el hechizo LUZ (fases, invertible) y el fantasma de test
# con dos hechizos (mordisco no counterable).
# ============================================================================
scene act1_test

# --- Montaje del banco de pruebas (antes en act1_test_setup) ---
# Misma config que act1_forest: anchura real del mapa (1440) y scroll por el
# jugador (user_right). Un auto_right con anchura 320 derivaría fuera del tilemap
# y provocaría una lectura no mapeada (cuelgue "unmapped read").
level forest_bg_tile forest_bg_map forest_front_tile forest_front_map forest_pal 1440 user_right 3
limits 0 134 275 172
set rod on                    # vara: fijar ANTES de character CHR_linus (decide su sprite)
character CHR_linus
character CHR_clio             # para probar show/hide desde el DSL
active CHR_linus
move_instant CHR_linus 140 154
show CHR_linus on
move_instant CHR_clio 70 154  # Clio empieza oculta; el DSL la muestra/oculta
enable_spell SPELL_THUNDER
enable_spell SPELL_HIDE
enable_spell SPELL_FIRE
enable_spell SPELL_LIGHT       # LUZ: solo existe habilitado aquí (fases + invertible)

say_cluster ACT1_TEST A1_TEST_INTRO sound
wait_press                   # pausa de cutscene: esperar pulsación de A (op nuevo)

# Flags base para toda la sesión de test
set movement on
set scroll on
set interface on

# ----------------------------------------------------------------------------
label hub
say ACT1_TEST A1_TEST_HUB silent
choice ACT1_TEST_HUB 0
branch 0 goto sec_dialogos
branch 1 goto sec_hechizos
branch 2 goto sec_combate
# opción 3 (o cualquier otra): terminar
say ACT1_TEST A1_TEST_BYE sound
fade_out 60
next_scene act1_bedroom

# ----------------------------------------------------------------------------
# SECCIÓN 1 — Diálogos: caras/lados, animación por DSL, quiz anidado con reintentos
label sec_dialogos
say ACT1_TEST A1_TEST_DLG_CLIO sound      # cara de Clio a la DERECHA
say ACT1_TEST A1_TEST_DLG_XANDER sound    # cara de Xander a la IZQUIERDA
say ACT1_TEST A1_TEST_ANIM silent
anim CHR_linus ANIM_MAGIC                 # op nuevo: animación desde el DSL
wait 15
anim CHR_linus ANIM_IDLE

label quiz_q1
say ACT1_TEST A1_TEST_QUIZ_Q1 silent
choice ACT1_TEST_QUIZ 0
branch 1 goto quiz_q2                     # "Cuatro" es la correcta
say ACT1_TEST A1_TEST_QUIZ_BAD silent
goto quiz_q1                              # reintento en bucle

label quiz_q2
say ACT1_TEST A1_TEST_QUIZ_Q2 silent
choice ACT1_TEST_QUIZ 1
branch 2 goto quiz_confirm                # "Esconderse" (FA SOL SOL FA) es palíndromo
say ACT1_TEST A1_TEST_QUIZ_BAD silent
goto quiz_q2

label quiz_confirm                        # choice ANIDADO: confirmación con vuelta atrás
say ACT1_TEST A1_TEST_QUIZ_CONF silent
choice ACT1_TEST_QUIZ 2
branch 1 goto quiz_q2                     # "No" → repetir la pregunta 2
say ACT1_TEST A1_TEST_QUIZ_OK sound
goto hub

# ----------------------------------------------------------------------------
# SECCIÓN 2 — Hechizos: casts scripted + dos puzzles de secuencia
label sec_hechizos
say ACT1_TEST A1_TEST_DEMO_CAST silent
cast SPELL_SLEEP direct
wait_spell
say ACT1_TEST A1_TEST_LIGHT_DEMO silent
cast SPELL_LIGHT direct                   # LUZ: efecto 100% por fases (cian→blanco)
wait_spell

say ACT1_TEST A1_TEST_PUZ_CHOICE silent
choice ACT1_TEST_CHOICE 0
branch 1 goto puz2

# Puzzle 1: básico (tres directos, con zona para fire)
say_cluster ACT1_TEST A1_TEST_PUZZLE_INTRO sound
zone ZONE_CAULDRON
set spells on
puzzle_sequence puerta_test thunder:direct fire:direct hide:direct
wait_puzzle puerta_test
if_puzzle_solved puerta_test goto puz1_ok
say ACT1_TEST A1_TEST_NEVER silent        # inalcanzable (centinela)
label puz1_ok
zone ZONE_NONE
set spells off
say ACT1_TEST A1_TEST_PUZZLE_OK sound
goto hub

# Puzzle 2: con paso INVERTIDO (luz se puede castear al revés)
label puz2
say_cluster ACT1_TEST A1_TEST_PUZ2_INTRO sound
set spells on
puzzle_sequence eco_test thunder:direct light:reversed hide:direct
wait_puzzle eco_test
set spells off
say ACT1_TEST A1_TEST_PUZZLE_OK sound
goto hub

# ----------------------------------------------------------------------------
# SECCIÓN 3 — Combate: menú anidado (hechizos / físico)
label sec_combate
say ACT1_TEST A1_TEST_COMBAT_MENU silent
choice ACT1_TEST_COMBAT_MENU 0
branch 1 goto sec_melee
branch 2 goto hub

# 3a — Por hechizos: dos oleadas (clásico counterable + multi-hechizo)
set spells on
say ACT1_TEST A1_TEST_COMBAT sound
call act1_test_ghost                      # oleada 1: WeaverGhost clásico
combat
say ACT1_TEST A1_TEST_WAVE2 sound
call act1_test_ghost2                     # oleada 2: TESTGHOST (thunder + mordisco)
combat
set interface on                          # combat_init la mostró; asegurar estado
say ACT1_TEST A1_TEST_VICTORY sound
goto hub

# 3b — Físico: 3 jabalíes, Linus SIN vara, golpes con A (combat/melee.c)
label sec_melee
set spells off                            # sin notas: el botón A es el golpe
say ACT1_TEST A1_TEST_MELEE sound
call act1_test_boars                      # quita la vara, coloca a Clio y corre el melee
set spells on                             # restaurar para el resto del banco
say ACT1_TEST A1_TEST_VICTORY sound
goto hub
