# Acto 1 — Hall: Clio y Xander hablan de los Tejedores
# La escena narrativa por excelencia: puro DSL (setup incluido).
scene act1_hall

# --- Montaje del nivel y colocación inicial (antes en act1_hall_setup) ---
level historians_bg_tile historians_bg_map historians_front_tile historians_front_map historians_pal SCREEN_WIDTH auto_right 3
character CHR_linus
character CHR_clio
character CHR_xander
move_instant CHR_clio 40 174
move_instant CHR_linus 360 164
look CHR_clio left        # Clio mira a la derecha (flipH=false)
look CHR_linus right      # Linus mira a la izquierda (flipH=true)
show CHR_clio on
show CHR_linus on

say_cluster ACT1_HALL A1_HALL_GUILD_YEAR sound
move CHR_linus 200 174
say_cluster ACT1_HALL A1_HALL_CLIO_LATE sound

# Entrada de Xander
move CHR_clio 100 154
wait 10
look CHR_clio right
move_instant CHR_xander -30 174
show CHR_xander on
move CHR_xander 40 174
say_cluster ACT1_HALL A1_HALL_XANDER_AWAKE sound

# Primer choice: la respuesta usa el texto base + la opción elegida
choice ACT1_HALL_CHOICE 0
say_response ACT1_HALL A1_HALL_XANDER_ABILITY sound
say_cluster ACT1_HALL A1_HALL_XANDER_FATHER_WANTED sound

# Segundo choice
choice ACT1_HALL_CHOICE 1
look CHR_clio left
say_response ACT1_HALL A1_HALL_CLIO_IF_XANDER_WANTS sound

wait 20

next_scene act1_forest
