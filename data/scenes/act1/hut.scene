# Acto 1 — Escena 5: choza de los Tejedores / telar roto (guión definitivo)
# Exploración libre con puntos de inspección (bastidor, hilos); interactuar
# con el bastón dispara el rayo, la recogida y el patrón Electricidad. La voz
# de Bobbin suena por primera vez y una sombra se mueve al salir.
# Textos placeholder pendientes de guión.
scene act1_hut

level hut_bg_tile hut_bg_map hut_front_tile hut_front_map hut_pal 640 user_right 3
limits 0 134 275 172
# Cajas de colisión explícitas: cubren el sprite VISIBLE para que interactuar
# no exija colocarse por encima de donde se ve el objeto
item 0 item_hut_staff PAL_BACKGROUND 430 150 40 0 10 8 CALCULATE_DEPTH        # el bastón (resonando)
item 1 item_hut_loom_debris PAL_BACKGROUND 200 110 48 0 6 16 FORCE_BACKGROUND # bastidor roto (apoyado en la pared)
item 2 item_hut_threads PAL_BACKGROUND 500 146 32 0 8 12 CALCULATE_DEPTH      # hilos ennegrecidos
set rod off
call act1_hut_start           # dentro de la choza no hay antorcha: sprite norod
character CHR_linus
character CHR_clio
active CHR_linus
move_instant CHR_linus -30 160
move_instant CHR_clio -60 160
follow CHR_clio on
show CHR_linus on
show CHR_clio on

say_cluster ACT1_HUT A1_HUT_ENTER sound   # "Aquí vivió alguien..."
move CHR_linus 50 160
say_cluster ACT1_HUT A1_HUT_LOOM sound    # el telar roto, se hace de noche

# Exploración libre: inspecciones opcionales; tocar el bastón continúa
set movement on
set scroll on
call act1_hut_items

# Cutscene del bastón: el rayo, la recogida y el patrón Electricidad
set movement off
set scroll off
say_cluster ACT1_HUT A1_HUT_STAFF sound   # "¿Qué es eso?" / "No lo toques"
call act1_hut_lightning
say_cluster ACT1_HUT A1_HUT_SYSTEM sound  # "Has obtenido el bastón..."
say_cluster ACT1_HUT A1_HUT_AWED sound    # "Lo he oído... Aquí"

# Primera llamada directa de Bobbin
say_cluster ACT1_HUT A1_HUT_BOBBIN sound  # "El tejido se está rompiendo..."

# Al salir, algo antiguo despierta entre los restos del telar
say_cluster ACT1_HUT A1_HUT_LEAVE sound   # "Es muy tarde... debemos volver ya"
call act1_hut_shadow
say ACT1_HUT A1_HUT_SHADOW sound
next_scene act1_return
