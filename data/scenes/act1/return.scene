# Acto 1 — Escena 6: regreso hacia la nave (guión definitivo)
# Es de NOCHE y se recorre el mismo bosque DE DERECHA A IZQUIERDA, ya sin
# antorcha. Fases: emboscada de jabalíes (solo el TRUENO los ahuyenta: melee
# en modo trueno) y los espectros del Caos (combate por hechizos: se vencen
# con el trueno invertido, tal y como ya está programado).
scene act1_return

level forest_bg_tile forest_bg_map forest_front_tile forest_front_map forest_dark_pal 1440 user_left 3
limits 0 134 275 172
set rod on                    # ya tiene el bastón; la antorcha se apagó en la choza
character CHR_linus
character CHR_clio
active CHR_linus
move_instant CHR_linus 350 154
move_instant CHR_clio 380 154
follow CHR_clio on
show CHR_linus on
show CHR_clio on
enable_spell SPELL_THUNDER

call act1_return_start         # viento nocturno
say_cluster ACT1_RETURN A1_RETURN_START sound   # "Camina. No mires atrás"
move CHR_linus 250 154
look CHR_linus left

# Caminar hacia la izquierda (la nave queda al fondo)
set movement on
set scroll on
set interface on
set spells on
wait_scroll_left 900

# FASE 1 — Emboscada de jabalíes: sin fuego, solo el TRUENO los ahuyenta
label ret_boars
say_cluster ACT1_RETURN A1_RETURN_BOARS sound   # "Otra vez. Y ahora no tengo fuego"
call act1_return_boars                          # spawnea y deja la config (trueno ahuyenta)
combat
if_defeated goto ret_boars_fail
say_cluster ACT1_RETURN A1_RETURN_BOARS_WON sound  # "Han retrocedido / Volverán"

# FASE 2 — Espectros del Caos (combate por hechizos: trueno invertido)
set movement on
wait_scroll_left 400
label ret_ghosts
say_cluster ACT1_RETURN A1_RETURN_GHOSTS sound  # "¿Qué son esas cosas?"
call act1_return_ghosts
combat
if_defeated goto ret_ghosts_fail
say_cluster ACT1_RETURN A1_RETURN_GHOSTS_WON sound  # "Se han ido / Se han retirado"

say_cluster ACT1_RETURN A1_RETURN_DONE sound    # la nave a la vista
next_scene act1_coast_end

label ret_boars_fail
say ACT1_RETURN A1_RETURN_BOBBIN_HINT sound     # Bobbin: "Canta el patrón de los cielos"
goto ret_boars

label ret_ghosts_fail
say ACT1_RETURN A1_RETURN_DEFEAT sound          # Bobbin: "La solución es a veces..."
goto ret_ghosts
