# Acto 1, Escena 3 — Hall: Clio y Xander hablan de los Tejedores
# La escena narrativa por excelencia: casi puro DSL.
scene act1_scene3

call act1_scene3_setup       # nivel del hall, personajes en posición

say_cluster ACT1_DIALOG2 A1D2_GUILD_YEAR sound
move CHR_linus 200 174
say_cluster ACT1_DIALOG2 A1D2_CLIO_LATE sound

# Entrada de Xander
move CHR_clio 100 154
wait 10
look CHR_clio right
move_instant CHR_xander -30 174
show CHR_xander on
move CHR_xander 40 174
say_cluster ACT1_DIALOG2 A1D2_XANDER_AWAKE sound

# Primer choice: la respuesta usa el texto base + la opción elegida
choice ACT1_CHOICE1 0
say_response ACT1_DIALOG2 A1D2_XANDER_ABILITY sound
say_cluster ACT1_DIALOG2 A1D2_XANDER_FATHER_WANTED sound

# Segundo choice
choice ACT1_CHOICE1 1
look CHR_clio left
say_response ACT1_DIALOG2 A1D2_CLIO_IF_XANDER_WANTS sound

wait 20

next_scene 1 5
