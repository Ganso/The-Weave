# Acto 1, Escena 2 — Pasillo de los historiadores: los libros y los recuerdos
scene act1_scene2

call act1_scene2_setup       # nivel del pasillo, items, Linus

say_cluster SYSTEM_DIALOG SYSMSG_DEMO_TITLE sound   # aviso de demo técnica

call act1_scene2_entry       # entrada de Linus por la derecha

say_cluster ACT1_DIALOG1 A1D1_OVERSLEPT silent

set scroll on
set movement on

call act1_scene2_items       # bucle de libros/puertas/mapas + salida al leer ambos libros

next_scene 1 3
