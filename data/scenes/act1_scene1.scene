# Acto 1, Escena 1 — Dormitorio: la visita del cisne y el primer patrón
scene act1_scene1

call act1_scene1_setup       # nivel nocturno, personajes, items
call act1_scene1_swan        # cinemática del cisne (flash + diálogo + flash)
call act1_scene1_wake        # amanece, Linus se levanta, control al jugador
call act1_scene1_items       # bucle de items: cama, silla, ventana, armario (aprende sleep)

say ACT1_DIALOG4 A1D4_MOTHER_CALLS sound
say ACT1_DIALOG4 A1D4_TOO_LATE silent

next_scene 1 2
